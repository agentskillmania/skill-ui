{
  "name": "@agentskillmania/skill-ui-theme",
  "version": "0.1.0",
  "description": "Theme and style utilities for @agentskillmania UI components.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "demo": "vite serve demo -c demo/vite.config.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:coverage": "vitest run test/unit --coverage",
    "test:watch": "vitest watch test/unit",
    "prepublishOnly": "pnpm test:unit && pnpm build"
  },
  "author": {
    "name": "yusangeng",
    "email": "yusangeng@outlook.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agentskillmania/skill-ui.git",
    "directory": "packages/theme"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "antd": "^6.0.0"
  },
  "devDependencies": {
    "@ant-design/x": "^2.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.0.0",
    "antd": "^6.3.3",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
